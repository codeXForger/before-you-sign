# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.local

# logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# env files (keep .env.example tracked; ignore real env files)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor & IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo

# tool / agent local state
.claude/settings.local.json
.claude/skills/
.cursor/
.aider*
.history/

# user-uploaded test fixtures
sample-agreements/
*.pdf
!public/**/*.pdf

# OS junk
.AppleDouble
.LSOverride
Icon
._*

# misc temp
tmp/
.tmp/
*.tmp
